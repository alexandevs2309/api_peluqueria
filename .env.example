# =============================================================================
# AURON SUITE — Variables de entorno
# Copia este archivo como .env.prod y rellena los valores reales.
# NUNCA commitees .env.prod ni ningún archivo con credenciales reales.
# =============================================================================

# =============================================================================
# DJANGO
# =============================================================================
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-real-secret-key

DEBUG=False

# Dominio(s) separados por coma. Incluir dominio real + subdominio API si aplica.
# Ejemplo: tudominio.com,api.tudominio.com,*.tudominio.com
ALLOWED_HOSTS=tudominio.com,api.tudominio.com

# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================
# Opción A: URL completa (sobreescribe DB_* individuales)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Opción B: Variables individuales
DB_NAME=barbershop_db
DB_USER=postgres
# Generar con: openssl rand -base64 32
DB_PASSWORD=change-me-strong-db-password
DB_HOST=db
DB_PORT=5432
CONN_MAX_AGE=600

# =============================================================================
# REDIS
# =============================================================================
# Generar con: openssl rand -base64 32
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@redis:6379/0

# =============================================================================
# CELERY
# =============================================================================
CELERY_BROKER_URL=redis://:change-me-strong-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-strong-redis-password@redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# =============================================================================
# CORS / CSRF
# =============================================================================
# Orígenes permitidos para el frontend (HTTPS en producción)
# Incluye tu dominio real del frontend explícitamente, por ejemplo:
# Cloudflare Pages: CORS_ALLOWED_ORIGINS=https://miapp.pages.dev,https://app.tudominio.com
# Vercel:           CORS_ALLOWED_ORIGINS=https://miapp.vercel.app,https://app.tudominio.com
CORS_ALLOWED_ORIGINS=https://app.tudominio.com
# Solo si necesitas un patrón temporal muy controlado:
# CORS_ALLOWED_ORIGIN_REGEXES=
# Orígenes de confianza para CSRF (debe coincidir con el frontend)
# Ejemplo Cloudflare Pages:
# CSRF_TRUSTED_ORIGINS=https://miapp.pages.dev,https://app.tudominio.com,https://tudominio.com
CSRF_TRUSTED_ORIGINS=https://app.tudominio.com,https://tudominio.com

# =============================================================================
# STRIPE
# =============================================================================
# TEST MODE (desarrollo / staging): https://dashboard.stripe.com/test/apikeys
# LIVE MODE (produccion real):      https://dashboard.stripe.com/apikeys
# Usar sk_test_ hasta tener clientes reales. El sistema emite warning si
# detecta sk_test_ con DEBUG=False, pero no bloquea el arranque.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook local con Stripe CLI: stripe listen --forward-to localhost:8000/api/billing/webhook/
# Webhook produccion: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...


# =============================================================================
# PAYPAL
# =============================================================================
# SANDBOX (desarrollo / staging):
#   - Crear app sandbox en https://developer.paypal.com
#   - Usar cuenta buyer sandbox para pagar pruebas
# LIVE (produccion real):
#   - Crear app live en PayPal Developer Dashboard
#   - Cambiar PAYPAL_SANDBOX=False
#   - Usar credenciales live distintas a las sandbox
PAYPAL_CLIENT_ID=CLIENT-ID-GENERATE-REAL-KEYS-IN-PAYPAL-DASHBOARD
PAYPAL_SECRET=SECRET-KEY-GENERATE-REAL-KEYS-IN-PAYPAL-DASHBOARD
PAYPAL_SANDBOX=True

# Webhook ID para PayPal (obligatorio si PAYPAL_SANDBOX=False)
# Obtener en: https://developer.paypal.com/dashboard/applications
# PAYPAL_WEBHOOK_ID=WEBHOOK-ID-GENERATE-IN-PAYPAL-DASHBOARD

# =============================================================================
# TWILIO (SMS)
# =============================================================================
# Obtener credenciales en: https://console.twilio.com
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# =============================================================================
# AWS S3 (File Storage alternativo a Cloudinary)
# =============================================================================
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_STORAGE_BUCKET_NAME=...
# AWS_S3_REGION_NAME=us-east-1

# =============================================================================
# EMAIL (Resend SMTP / SendGrid / console fallback)
# =============================================================================
# El backend prueba en orden: Resend SMTP -> SendGrid -> console (no envía).
# Solo UNA de las opciones necesita estar activa.

# Opción A: Resend SMTP (recomendado para producción)
# Obtener API key en: https://resend.com
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_...
EMAIL_USE_TLS=True

# Opción B: SendGrid
# SENDGRID_API_KEY=SG....
# SENDGRID_FROM_EMAIL=noreply@tudominio.com

# Remitente por defecto (todos los emails transaccionales usan esta dirección)
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# En desarrollo/testing, redirige TODOS los emails a esta dirección
# (útil con Resend en modo test que solo envía a emails verificados)
# DEV_EMAIL_OVERRIDE=developer@example.com

# =============================================================================
# SENTRY (Observabilidad)
# =============================================================================
# Obtener en: https://sentry.io
SENTRY_DSN=https://...@sentry.io/...
DISABLE_SENTRY=False
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# =============================================================================
# CLOUDINARY (Media Storage)
# =============================================================================
# Opcional: si no se configura, usa almacenamiento local (solo DEBUG=True).
# En produccion sin Cloudinary, el backend falla al arrancar.
# Obtener credenciales en: https://cloudinary.com/console
# USE_CLOUDINARY=True
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=tu-api-secret

# =============================================================================
# JWT
# =============================================================================
# Clave separada de SECRET_KEY para firmar JWT. Si no se define, usa SECRET_KEY.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# JWT_SIGNING_KEY=...

# =============================================================================
# FRONTEND
# =============================================================================
# Dominio principal del frontend. En producción Django lo usa como fallback
# para CORS/CSRF si esas variables no se definen explícitamente.
# Ejemplo Cloudflare Pages: https://miapp.pages.dev
FRONTEND_URL=https://app.tudominio.com

# =============================================================================
# ALERTAS FINANCIERAS
# =============================================================================
# Emails separados por coma que reciben alertas de reconciliación Stripe
FINANCE_ALERT_EMAILS=finance@tudominio.com,cto@tudominio.com

# =============================================================================
# SUPERADMIN (solo para script de creación inicial, no usar en runtime)
# =============================================================================
SUPERADMIN_EMAIL=admin@tudominio.com
# Generar con: openssl rand -base64 24
SUPERADMIN_PASSWORD=change-me-strong-admin-password

# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_PASSWORD=change-me-strong-grafana-password

# =============================================================================
# OPCIONALES
# =============================================================================
# Límite de payload en bytes (default: 5MB)
# DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
# FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
# Minutos de gracia para citas sin show
# APPOINTMENT_NO_SHOW_GRACE_MINUTES=15

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Sobrescribe emails en desarrollo (todas las notificaciones van a esta dirección)
# DEV_EMAIL_OVERRIDE=

# Ruta de storage para archivos media en producción
# MEDIA_ROOT=/data/media

# Soporte publico mostrado en respuestas de tenant inactivo
SUPPORT_EMAIL=soporte@auron-suite.com
SUPPORT_URL=https://auron-suite.com/soporte

# Solo staging con claves Stripe test y DEBUG=False. En produccion real dejar False.
STRIPE_LIVE_MODE_CONFIRMED=False
