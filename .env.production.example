# ==========================================
# VARIABLES DE ENTORNO - PRODUCCIÓN
# ==========================================

# ✅ OBLIGATORIAS - El sistema NO arranca sin estas
SECRET_KEY=GENERAR_CLAVE_SEGURA_50_CARACTERES_MINIMO
DEBUG=False
ALLOWED_HOSTS=tu-dominio.com,api.tu-dominio.com
CSRF_TRUSTED_ORIGINS=https://tu-dominio.com,https://app.tu-dominio.com

# ✅ BASE DE DATOS - PostgreSQL OBLIGATORIO
DATABASE_URL=postgres://usuario:password@host:5432/database_name

# ✅ REDIS - OBLIGATORIO para cache y Celery
REDIS_URL=redis://usuario:password@host:6379/1
REDIS_PASSWORD=password_redis_seguro

# ✅ CELERY - OBLIGATORIO para tareas asíncronas
CELERY_BROKER_URL=redis://usuario:password@host:6379/0
CELERY_RESULT_BACKEND=redis://usuario:password@host:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# ✅ CORS - Frontend permitido
CORS_ALLOWED_ORIGINS=https://app.tu-dominio.com,https://admin.tu-dominio.com

# ✅ SENTRY - OBLIGATORIO para monitoreo
SENTRY_DSN=https://tu-dsn@sentry.io/proyecto-id
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0
DISABLE_SENTRY=False

# ✅ EMAIL - OBLIGATORIO para notificaciones
SENDGRID_API_KEY=SG.tu_clave_sendgrid_aqui
SENDGRID_FROM_EMAIL=noreply@tu-dominio.com

# ✅ PAGOS - Stripe producción
STRIPE_SECRET_KEY=sk_live_tu_clave_stripe_live
STRIPE_PUBLISHABLE_KEY=pk_live_tu_clave_publica_live

# ==========================================
# VARIABLES OPCIONALES
# ==========================================

# 🔧 Conexiones de BD
CONN_MAX_AGE=300

# 🔧 Geo-restricciones (opcional)
GEO_LOCK_ENABLED=False
GEOIP_PATH=/path/to/geoip/database

# ==========================================
# VARIABLES QUE NO DEBEN EXISTIR EN PRODUCCIÓN
# ==========================================

# ❌ NUNCA en producción:
# DJANGO_SETTINGS_MODULE=backend.settings  # Usar settings_production
# CELERY_TASK_ALWAYS_EAGER=True
# DEBUG=True
# CORS_ALLOW_ALL_ORIGINS=True

# ==========================================
# DOCKER COMPOSE ESPECÍFICAS
# ==========================================

# Para docker-compose.prod.yml
DB_NAME=saas_peluquerias_prod
DB_USER=saas_user_prod
DB_PASSWORD=password_super_seguro_bd
POSTGRES_PASSWORD=password_super_seguro_bd

# ==========================================
# VALIDACIÓN DE VARIABLES
# ==========================================

# Usar este comando para validar:
# python manage.py check --settings=backend.settings_production