# =============================================================================
# AURON SUITE — Variables de entorno para STAGING
# Copia este archivo como referencia, NO lo subas a git.
# Los valores SE INGRESAN MANUALMENTE en el dashboard de Render.
# =============================================================================
#
# INSTRUCCIONES:
# 1. Crea un Web Service en Render (tipo Docker).
# 2. Agrega cada variable de abajo una por una en el panel.
# 3. Marca todas como "secret" para que Render oculte los valores.
# 4. Ejecuta un Deploy manual (Clear build cache & deploy).
#
# =============================================================================
# ⚠️ IMPORTANTE: Al editar env vars en Render, SIEMPRE lee las vars
#    actuales primero (GET /v1/services/{id}/env-vars con limit=100).
#    El PUT reemplaza TODO el listado, no hace merge.
# =============================================================================

# =============================================================================
# DJANGO
# =============================================================================
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=staging-secret-key-change-me-with-generated-key

DEBUG=False

# Dominio del backend de staging
ALLOWED_HOSTS=staging-api.auronsuite.com

# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================
# Render te da una DB PostgreSQL gratuita con 1GB.
# Crear en: Render Dashboard > PostgreSQL > New PostgreSQL
# La URL aparece en la sección "Connections" de la DB.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Schema separado para staging (misma BD que producción, tablas separadas)
DB_SCHEMA=staging

CONN_MAX_AGE=600

# =============================================================================
# REDIS (opcional en staging)
# =============================================================================
# Redis es opcional en staging. Sin Redis, el backend usa LocMemCache
# como fallback automático.
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CELERY
# =============================================================================
# En staging sin worker, las tareas se ejecutan síncronas.
CELERY_TASK_ALWAYS_EAGER=True

# =============================================================================
# CORS / CSRF
# =============================================================================
# Dominio del frontend de staging
CORS_ALLOWED_ORIGINS=https://staging.auronsuite.com
CSRF_TRUSTED_ORIGINS=https://staging.auronsuite.com,https://staging-api.auronsuite.com

# =============================================================================
# STRIPE (TEST MODE — sk_test_ / pk_test_)
# =============================================================================
# Usar claves de prueba de Stripe. El prefijo sk_test_ es seguro.
# Stripe Dashboard > Developers > API Keys (modo Test)
# NO usar claves live (sk_live_) en staging.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_LIVE_MODE_CONFIRMED=False

# =============================================================================
# PAYPAL (SANDBOX MODE)
# =============================================================================
# Usar credenciales del dashboard de PayPal Developer (sandbox).
PAYPAL_CLIENT_ID=client-id-from-paypal-sandbox
PAYPAL_SECRET=secret-from-paypal-sandbox
PAYPAL_SANDBOX=True

# =============================================================================
# EMAIL (Resend SMTP — modo test)
# =============================================================================
# En staging, Resend solo envía a emails verificados.
# Usa DEV_EMAIL_OVERRIDE para redirigir todo a tu correo.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxx
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@auronsuite.com

# Redirige todos los emails a una dirección durante pruebas
DEV_EMAIL_OVERRIDE=tu-email@example.com

# =============================================================================
# SENTRY (Observabilidad) — opcional en staging
# =============================================================================
DISABLE_SENTRY=True
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=staging

# =============================================================================
# CLOUDINARY (Media Storage) — opcional en staging
# =============================================================================
# Sin Cloudinary, el backend usa FileSystemStorage como fallback.
# USE_CLOUDINARY=True
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=tu-api-secret

# =============================================================================
# JWT
# =============================================================================
# Clave separada de SECRET_KEY para firmar JWT.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SIGNING_KEY=staging-jwt-key-change-me-with-generated-key

# =============================================================================
# FRONTEND
# =============================================================================
FRONTEND_URL=https://staging.auronsuite.com

# =============================================================================
# SUPERADMIN (creación inicial)
# =============================================================================
SUPERADMIN_EMAIL=tu-email@example.com
SUPERADMIN_PASSWORD=staging-admin-password-change-me

# =============================================================================
# CONTACTO / SOPORTE
# =============================================================================
SUPPORT_EMAIL=soporte@auronsuite.com
SUPPORT_URL=https://auronsuite.com/soporte

# =============================================================================
# OPCIONALES
# =============================================================================
# FINANCE_ALERT_EMAILS=finance@example.com
# LOG_LEVEL=INFO
